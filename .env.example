# Supabase project configuration
# Copy this file to .env and fill in your values for local development.
# In GitHub Actions / GitHub Pages, set these as environment secrets in the `supabase` environment
# at Settings → Environments → supabase → Environment secrets (without the VITE_ prefix).

VITE_SUPABASE_PROJECT_ID=your_project_id
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_key
VITE_SUPABASE_URL=https://your_project_id.supabase.co

# ---------------------------------------------------------------------------
# Evolution API v2 – WhatsApp integration
# ---------------------------------------------------------------------------
# For local development with docker-compose, the defaults below are pre-configured
# in docker-compose.yml and do not need to be set explicitly.
#
# For production (Supabase cloud), set these as edge function secrets:
#   supabase secrets set EVOLUTION_API_URL=https://your-evolution-api.example.com
#   supabase secrets set EVOLUTION_API_KEY=your-production-api-key
#   supabase secrets set SUPABASE_PUBLIC_URL=https://your-project-id.supabase.co
#   supabase secrets set WEBHOOK_SECRET=your-strong-random-secret
# ---------------------------------------------------------------------------

# URL pública do projeto Supabase usada para registrar webhooks que serão
# recebidos pela Evolution API fora da rede interna do Supabase.
SUPABASE_PUBLIC_URL=https://your_project_id.supabase.co

# URL públca da Evolution API (local: http://localhost:8081)
EVOLUTION_API_URL=http://localhost:8081

# Chave mestra de autenticação da Evolution API
EVOLUTION_API_KEY=claris-evolution-local-key

# Segredo compartilhado para validar webhooks recebidos da Evolution API
WEBHOOK_SECRET=claris-webhook-secret-local

# (Opcional) URI de conexão PostgreSQL usada pela Evolution API.
# Por padrão usa o Postgres do Supabase local (porta 54322).
# EVOLUTION_DB_URI=postgresql://postgres:postgres@localhost:54322/postgres
